{
  "name": "potato-planner",
  "version": "1.0.0",
  "description": "더덕 플래너 - 데스크톱 플래너 위젯",
  "main": "main.js",
  "author": "MeDeoDuck",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.medeoduck.potatoplanner",
    "productName": "DeodeokPlanner",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css",
      "store.js"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3"
  }
}
